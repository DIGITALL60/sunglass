# Puerto donde corre el servidor (Railway lo asigna automáticamente)
PORT=3000

# Conexión a PostgreSQL (Railway provee esta variable automáticamente si usas Railway DB)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Clave secreta para firmar tokens JWT — cambiá esto en producción
JWT_SECRET=cambia-este-secreto-en-produccion

# Entorno (production | development)
NODE_ENV=production

# Nivel de logs (info | debug | warn | error)
LOG_LEVEL=info
